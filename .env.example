# ==========================================
# CONFIGURACIÓN - Lifebox Radar
# ==========================================
# Copia este archivo a .env y completa tus valores
# NO compartir en repositorios públicos
# ==========================================

# ==========================================
# GOOGLE CLOUD CONFIGURATION
# ==========================================
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto
# 3. Habilita BigQuery API
# 4. Crea una Service Account con rol BigQuery Admin
# 5. Descarga las credenciales en formato JSON

GCP_PROJECT_ID=tu-proyecto-gcp-aqui
# Ruta a tu archivo credenciales_gcp.json
GCP_CREDENTIALS_PATH=credenciales_gcp.json

# ==========================================
# TELEGRAM NOTIFICATIONS
# ==========================================
# 1. Busca @BotFather en Telegram
# 2. Envía /newbot y sigue las instrucciones
# 3. Guarda el TOKEN que te proporciona

# Token de tu Bot de Telegram
TELEGRAM_TOKEN=123456789:ABCDEfghijklmnopqrstuvwxyz123456789

# Tu Chat ID en Telegram
# Para obtenerlo:
# 1. Envía un mensaje a tu bot
# 2. Abre: https://api.telegram.org/bot[TOKEN]/getUpdates
# 3. Busca "id" en la respuesta
TELEGRAM_CHAT_ID=987654321

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# SCRAPER CONFIGURATION (Opcional)
# ==========================================
# Timeout en segundos para Selenium
SCRAPER_TIMEOUT=30

# Ejecutar navegador en modo headless (sin interfaz visual)
SCRAPER_HEADLESS=true

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Ubicación para guardar logs
LOG_FILE=logs/lifebox_radar.log

# ==========================================
# SCHEDULER CONFIGURATION (Opcional)
# ==========================================
# Ejecutar scraping automáticamente cada X minutos
# 0 = desactivado
SCHEDULER_INTERVAL_MINUTES=60
